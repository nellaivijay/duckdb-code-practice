   "source": [
    "# Advanced Streamlit features solution\n",
    "advanced_features_app = '''\n",
    "import streamlit as st\n",
    "import duckdb\n",
    "import pandas as pd\n",
    "import time\n",
    "\n",
    "st.set_page_config(page_title=\"Advanced DuckDB App\", layout=\"wide\")\n",
    "\n",
    "# Session state for persistence\n",
    "if 'query_history' not in st.session_state:\n",
    "    st.session_state.query_history = []\n",
    "\n",
    "# Progress indicators\n",
    "with st.spinner(\"Loading data...\"):\n",
    "    time.sleep(2)\n",
    "    st.success(\"Data loaded!\")\n",
    "\n",
    "# File upload\n",
    "uploaded_file = st.file_uploader(\"Upload a file\", type=['csv', 'parquet'])\n",
    "if uploaded_file:\n",
    "    st.write(f\"Uploaded: {uploaded_file.name}\")\n",
    "\n",
    "# Status messages\n",
    "st.info(\"This is an informational message\")\n",
    "st.warning(\"This is a warning message\")\n",
    "st.error(\"This is an error message\")\n",
    "\n",
    "# Expander for additional content\n",
    "with st.expander(\"Show more details\"):\n",
    "    st.write(\"Additional information here\")\n",
    "\n",
    "# Tabs for organizing content\n",
    "tab1, tab2, tab3 = st.tabs([\"Overview\", \"Details\", \"Settings\"])\n",
    "with tab1:\n",
    "    st.write(\"Overview content\")\n",
    "with tab2:\n",
    "    st.write(\"Details content\")\n",
    "with tab3:\n",
    "    st.write(\"Settings content\")\n",
    "\n",
    "# Advanced data filtering\n",
    "con = duckdb.connect('data/duckdb_practice.db')\n",
    "df = con.execute(\"SELECT * FROM sample_customers\").df()\n",
    "\n",
    "col1, col2 = st.columns(2)\n",
    "with col1:\n",
    "    segment_filter = st.multiselect(\"Filter by Segment\", df['segment'].unique())\n",
    "with col2:\n",
    "    active_filter = st.selectbox(\"Filter by Status\", [\"All\", \"Active\", \"Inactive\"])\n",
    "\n",
    "filtered_df = df.copy()\n",
    "if segment_filter:\n",
    "    filtered_df = filtered_df[filtered_df['segment'].isin(segment_filter)]\n",
    "if active_filter != \"All\":\n",
    "    filtered_df = filtered_df[filtered_df['is_active'] == (active_filter == \"Active\")]\n",
    "\n",
    "st.write(f\"Showing {len(filtered_df)} records\")\n",
    "st.dataframe(filtered_df)\n",
    "'''\n",
    "\n",
    "# Save the advanced features app\n",
    "with open('data/advanced_streamlit_app.py', 'w') as f:\n",
    "    f.write(advanced_features_app)\n",
    "\n",
    "print(\"✓ Advanced Streamlit app created: data/advanced_streamlit_app.py\")\n",
    "print(\"To run: streamlit run data/advanced_streamlit_app.py\")\n",
    "print(\"\\nAdvanced features:\")\n",
    "print(\"- Session state management\")\n",
    "print(\"- Progress indicators and status messages\")\n",
    "print(\"- File upload functionality\")\n",
    "print(\"- Expandable sections and tabs\")\n",
    "print(\"- Advanced data filtering")
   ]
  }
