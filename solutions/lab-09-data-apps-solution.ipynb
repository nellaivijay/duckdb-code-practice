    "## 💻 Exercise 1: Build Complete Streamlit App - SOLUTION\n",
    "\n",
    "### Solution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Complete Streamlit app solution\n",
    "complete_streamlit_app = '''\n",
    "import streamlit as st\n",
    "import duckdb\n",
    "import pandas as pd\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "# Page configuration\n",
    "st.set_page_config(\n",
    "    page_title=\"DuckDB Analytics Dashboard\",\n",
    "    page_icon=\"🦆\",\n",
    "    layout=\"wide\"\n",
    ")\n",
    "\n",
    "# Database connection with caching\n",
    "@st.cache_resource\n",
    "def get_connection():\n",
    "    return duckdb.connect('data/duckdb_practice.db')\n",
    "\n",
    "con = get_connection()\n",
    "\n",
    "# Load data with caching\n",
    "@st.cache_data\n",
    "def load_data(table_name):\n",
    "    return con.execute(f\"SELECT * FROM {table}\").df()\n",
    "\n",
    "# Sidebar navigation\n",
    "page = st.sidebar.radio(\"Navigate\", [\"Data Explorer\", \"Analytics Dashboard\", \"SQL Query\", \"Settings\"])\n",
    "\n",
    "if page == \"Data Explorer\":\n",
    "    st.header(\"Data Explorer\")\n",
    "    \n",
    "    # Table selection\n",
    "    tables = con.execute(\"SHOW TABLES\").fetchall()\n",
    "    table_names = [t[0] for t in tables]\n",
    "    selected_tables = st.multiselect(\"Select Tables\", table_names)\n",
    "    \n",
    "    for table in selected_tables:\n",
    "        st.subheader(table)\n",
    "        df = load_data(table)\n",
    "        st.dataframe(df)\n",
    "        \n",
    "        # Column selection\n",
    "        columns = st.multiselect(f\"Select columns from {table}\", df.columns, df.columns[:3])\n",
    "        if columns:\n",
    "            st.dataframe(df[columns])\n",
    "\n",
    "elif page == \"Analytics Dashboard\":\n",
    "    st.header(\"Analytics Dashboard\")\n",
    "    \n",
    "    # Metric cards\n",
    "    col1, col2, col3 = st.columns(3)\n",
    "    \n",
    "    with col1:\n",
    "        total_customers = con.execute(\"SELECT COUNT(*) FROM sample_customers\").fetchone()[0]\n",
    "        st.metric(\"Total Customers\", total_customers)\n",
    "    \n",
    "    with col2:\n",
    "        total_products = con.execute(\"SELECT COUNT(*) FROM sample_products\").fetchone()[0]\n",
    "        st.metric(\"Total Products\", total_products)\n",
    "    \n",
    "    with col3:\n",
    "        total_orders = con.execute(\"SELECT COUNT(*) FROM sample_orders\").fetchone()[0]\n",
    "        st.metric(\"Total Orders\", total_orders)\n",
    "    \n",
    "    # Visualizations\n",
    "    tab1, tab2, tab3 = st.tabs([\"Customer Analysis\", \"Product Performance\", \"Sales Trends\"])\n",
    "    \n",
    "    with tab1:\n",
    "        segment_data = con.execute(\"\"\"\n",
    "            SELECT segment, COUNT(*) as count \n",
    "            FROM sample_customers \n",
    "            GROUP BY segment\n",
    "        \"\"\").df()\n",
    "        fig_pie = px.pie(segment_data, values='count', names='segment', \n",
    "                         title='Customer Segment Distribution')\n",
    "        st.plotly_chart(fig_pie, use_container_width=True)\n",
    "    \n",
    "    with tab2:\n",
    "        category_data = con.execute(\"\"\"\n",
    "            SELECT \n",
    "                p.category,\n",
    "                COUNT(o.order_id) as order_count,\n",
    "                SUM(o.total_amount) as total_revenue\n",
    "            FROM sample_products p\n",
    "            JOIN sample_orders o ON p.product_id = o.product_id\n",
    "            GROUP BY p.category\n",
    "            ORDER BY total_revenue DESC\n",
    "        \"\"\").df()\n",
    "        fig_bar = px.bar(category_data, x='category', y='total_revenue',\n",
    "                         title='Revenue by Category')\n",
    "        st.plotly_chart(fig_bar, use_container_width=True)\n",
    "    \n",
    "    with tab3:\n",
    "        sales_data = con.execute(\"\"\"\n",
    "            SELECT \n",
    "                order_date, \n",
    "                SUM(total_amount) as daily_sales\n",
    "            FROM sample_orders\n",
    "            GROUP BY order_date\n",
    "            ORDER BY order_date\n",
    "        \"\"\").df()\n",
    "        fig_line = px.line(sales_data, x='order_date', y='daily_sales',\n",
    "                         title='Daily Sales Trend')\n",
    "        st.plotly_chart(fig_line, use_container_width=True)\n",
    "\n",
    "elif page == \"SQL Query\":\n",
    "    st.header(\"SQL Query Interface\")\n",
    "    \n",
    "    query = st.text_area(\"Enter SQL Query\", height=200)\n",
    "    \n",
    "    if st.button(\"Execute Query\"):\n",
    "        try:\n",
    "            result = con.execute(query).df()\n",
    "            st.dataframe(result)\n",
    "            st.download_button(\"Download CSV\", result.to_csv(), \"query_result.csv\")\n",
    "        except Exception as e:\n",
    "            st.error(f\"Error: {e}\")\n",
    "\n",
    "elif page == \"Settings\":\n",
    "    st.header(\"Settings\")\n",
    "    \n",
    "    st.subheader(\"Database Configuration\")\n",
    "    memory_limit = st.slider(\"Memory Limit (GB)\", 1, 16, 4)\n",
    "    threads = st.slider(\"Threads\", 1, 16, 4)\n",
    "    \n",
    "    if st.button(\"Apply Settings\"):\n",
    "        con.execute(f\"SET memory_limit='{memory_limit}GB'\")\n",
    "        con.execute(f\"SET threads={threads}\")\n",
    "        st.success(\"Settings applied\")\n",
    "'''\n",
    "\n",
    "# Save the complete app\n",
    "with open('data/complete_streamlit_app.py', 'w') as f:\n",
    "    f.write(complete_streamlit_app)\n",
    "\n",
    "print(\"✓ Complete Streamlit app created: data/complete_streamlit_app.py\")\n",
    "print(\"To run: streamlit run data/complete_streamlit_app.py\")\n",
    "print(\"\\nApp features:\")\n",
    "print(\"- Multi-page navigation (Data Explorer, Analytics, SQL Query, Settings)\")\n",
    "print(\"- Interactive data exploration with table selection\")\n",
    "print(\"- Analytics dashboard with metrics and visualizations\")\n",
    "print(\"- SQL query interface with result export\")\n",
    "print(\"- Database configuration settings\")"
   ]
  },
